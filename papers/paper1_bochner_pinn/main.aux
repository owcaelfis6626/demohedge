\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces Bochner PINN: at each epoch $e$ the network $u_\theta $ and the FD reference $u_{\mathrm  {FD}}$ are both evaluated on a sub-grid $\mathcal  {G}_s(e)$ drawn uniformly at random from the full FD grid. Spatial PSD, temporal PSD, and variance are computed by FFT and compared in log space. The random re-sampling at each epoch prevents sub-grid overfit (Section~\ref {subsec:rand-subgrid}).}}{13}{figure.1}\protected@file@percent }
\newlabel{fig:method-schematic}{{1}{13}{Bochner PINN: at each epoch $e$ the network $u_\theta $ and the FD reference $u_{\mathrm {FD}}$ are both evaluated on a sub-grid $\mathcal {G}_s(e)$ drawn uniformly at random from the full FD grid. Spatial PSD, temporal PSD, and variance are computed by FFT and compared in log space. The random re-sampling at each epoch prevents sub-grid overfit (Section~\ref {subsec:rand-subgrid})}{figure.1}{}}
