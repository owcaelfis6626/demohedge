\@writefile{lof}{\contentsline {figure}{\numberline {7}{\ignorespaces Real-data calibration on six datasets: log-price variance ratio (target 1.0). Vanilla PINN (red) leaves a substantial gap on EUR/USD (vr~=~0.41), solar wind (0.69), and geomagnetic AE (0.26). Bochner PINN (blue) closes the gap to within 5--30\% of unity on all six datasets without per-dataset hyperparameter retuning. Datasets span sampling frequencies from minute (EUR/USD) to daily (BTC, crude, gas) and empirical kurtosis from 4.4 to 230.}}{71}{figure.7}\protected@file@percent }
\newlabel{fig:realworld}{{7}{71}{Real-data calibration on six datasets: log-price variance ratio (target 1.0). Vanilla PINN (red) leaves a substantial gap on EUR/USD (vr~=~0.41), solar wind (0.69), and geomagnetic AE (0.26). Bochner PINN (blue) closes the gap to within 5--30\% of unity on all six datasets without per-dataset hyperparameter retuning. Datasets span sampling frequencies from minute (EUR/USD) to daily (BTC, crude, gas) and empirical kurtosis from 4.4 to 230}{figure.7}{}}
