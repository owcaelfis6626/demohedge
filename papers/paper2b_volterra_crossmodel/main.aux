\citation{bennedsen2017hybrid}
\@writefile{lot}{\contentsline {table}{\numberline {2}{\ignorespaces ATM delta and bias under rough Heston ($\rho =-0.9$). Bias~A uses the \emph  {same} variance paths as the reference but an independent BM for correlation; it isolates the pure leverage-effect error. Bias~B uses the surrogate variance \emph  {and} an independent BM; it compounds variance-distribution and correlation errors. All biases in $\Delta $-units; reference $\Delta \approx 0.78$ for all $T$.}}{4}{table.2}\protected@file@percent }
\newlabel{tab:delta-bias}{{2}{4}{ATM delta and bias under rough Heston ($\rho =-0.9$). Bias~A uses the \emph {same} variance paths as the reference but an independent BM for correlation; it isolates the pure leverage-effect error. Bias~B uses the surrogate variance \emph {and} an independent BM; it compounds variance-distribution and correlation errors. All biases in $\Delta $-units; reference $\Delta \approx 0.78$ for all $T$}{table.2}{}}
\newlabel{tab:delta-bias@cref}{{[table][2][]2}{[1][3][]4}{}{}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces \textbf  {Rough Heston IV smiles: reference vs.\ surrogates.} Each panel shows one maturity. Reference (black solid) exhibits a pronounced left skew. Surrogate~B (red dashed, $\rho =-0.9$, wrong BM) is far from the reference; Surrogate~C (blue dotted, $\rho =0$) captures the level of the smile but not its skew. Overall RMSE: 7.8~vp (Surrogate~C) vs.\ 188~vp (Surrogate~B). }}{4}{figure.1}\protected@file@percent }
\newlabel{fig:rh-iv}{{1}{4}{\textbf {Rough Heston IV smiles: reference vs.\ surrogates.} Each panel shows one maturity. Reference (black solid) exhibits a pronounced left skew. Surrogate~B (red dashed, $\rho =-0.9$, wrong BM) is far from the reference; Surrogate~C (blue dotted, $\rho =0$) captures the level of the smile but not its skew. Overall RMSE: 7.8~vp (Surrogate~C) vs.\ 188~vp (Surrogate~B)}{figure.1}{}}
\newlabel{fig:rh-iv@cref}{{[figure][1][]1}{[1][4][]4}{}{}{}}
