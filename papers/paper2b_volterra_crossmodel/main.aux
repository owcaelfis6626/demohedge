\@writefile{lot}{\contentsline {table}{\numberline {11}{\ignorespaces Multi-maturity calibration to live SPY options ($S_0 = \$745.64$, $\rho = -0.85$, $26$ calibration points across three expirations). Overall IV RMSE $3.97$~vp; the short-end fits within $2\times $ bid/ask uncertainty, while the long-end shows a systematic under-pricing of OTM calls characteristic of single-kernel rough-vol calibrations (the surrogate's variance grows too slowly with $T$).}}{10}{table.11}\protected@file@percent }
\newlabel{tab:spy-multi}{{11}{10}{Multi-maturity calibration to live SPY options ($S_0 = \$745.64$, $\rho = -0.85$, $26$ calibration points across three expirations). Overall IV RMSE $3.97$~vp; the short-end fits within $2\times $ bid/ask uncertainty, while the long-end shows a systematic under-pricing of OTM calls characteristic of single-kernel rough-vol calibrations (the surrogate's variance grows too slowly with $T$)}{table.11}{}}
\newlabel{tab:spy-multi@cref}{{[table][11][]11}{[1][9][]10}{}{}{}}
