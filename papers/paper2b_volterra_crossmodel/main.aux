\@writefile{toc}{\contentsline {paragraph}{Two negative results: spectral matching of rough Heston $V$ makes things worse.}{7}{section*.12}\protected@file@percent }
\@writefile{lot}{\contentsline {table}{\numberline {7}{\ignorespaces Attempts to match rough Heston $V$ within the spectral framework all underperform the rBergomi-$V$ baseline. Spectral surrogates capture second-order statistics; rough Heston $V$'s skewness and heavy tails require higher-order modelling.}}{7}{table.7}\protected@file@percent }
\newlabel{tab:rh-negatives}{{7}{7}{Attempts to match rough Heston $V$ within the spectral framework all underperform the rBergomi-$V$ baseline. Spectral surrogates capture second-order statistics; rough Heston $V$'s skewness and heavy tails require higher-order modelling}{table.7}{}}
\newlabel{tab:rh-negatives@cref}{{[table][7][]7}{[1][7][]7}{}{}{}}
