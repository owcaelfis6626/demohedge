\@writefile{toc}{\contentsline {paragraph}{Setup: $z$-Cholesky and the BLP reference.}{4}{section*.5}\protected@file@percent }
\newlabel{eq:z-cholesky}{{1}{4}{Setup: $z$-Cholesky and the BLP reference}{equation.1}{}}
\newlabel{eq:z-cholesky@cref}{{[equation][1][]1}{[1][4][]4}{}{}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces \textbf  {Delta bias per strike and maturity.} Blue bars: Bias~A (same variance, fresh BM), the pure leverage contribution to delta that any marginal-matching surrogate misses. Orange bars: Bias~B (surrogate variance + fresh BM), compounded with the variance-distribution error, which dominates at $T=1$. Bias~A is negative for $K \leq 1.00$ (surrogate under-estimates delta for ITM/ATM calls) and slightly positive for deep OTM, a signature of the leverage effect on the conditional right-tail distribution. }}{5}{figure.2}\protected@file@percent }
\newlabel{fig:delta-bias}{{2}{5}{\textbf {Delta bias per strike and maturity.} Blue bars: Bias~A (same variance, fresh BM), the pure leverage contribution to delta that any marginal-matching surrogate misses. Orange bars: Bias~B (surrogate variance + fresh BM), compounded with the variance-distribution error, which dominates at $T=1$. Bias~A is negative for $K \leq 1.00$ (surrogate under-estimates delta for ITM/ATM calls) and slightly positive for deep OTM, a signature of the leverage effect on the conditional right-tail distribution}{figure.2}{}}
\newlabel{fig:delta-bias@cref}{{[figure][2][]2}{[1][4][]5}{}{}{}}
