\@writefile{lot}{\contentsline {table}{\numberline {3}{\ignorespaces IV RMSE vs BLP rBergomi reference ($\rho =-0.9$, 8k paths each) and ATM $\Delta $ at $T=0.50$. Causal $z$-Cholesky is 63$\times $ better than the circular architecture and reduces the delta bias by 60\% vs.\ the $\rho =0$ baseline.}}{6}{table.3}\protected@file@percent }
\newlabel{tab:causal-blp}{{3}{6}{IV RMSE vs BLP rBergomi reference ($\rho =-0.9$, 8k paths each) and ATM $\Delta $ at $T=0.50$. Causal $z$-Cholesky is 63$\times $ better than the circular architecture and reduces the delta bias by 60\% vs.\^^Mthe $\rho =0$ baseline}{table.3}{}}
\newlabel{tab:causal-blp@cref}{{[table][3][]3}{[1][5][]6}{}{}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces \textbf  {CausalSpectralFilter vs circular SpectralFilter ($\rho =-0.9$).} Each panel shows one maturity. BLP reference (black) has the correct left skew. Causal $z$-Cholesky (green dashed) tracks the reference closely at all strikes; causal $\rho =0$ baseline (blue dotted) matches the IV \emph  {level} but not the skew. Circular $z$-Cholesky (red dash-dot) is physically invalid (IVs exceed 100\% and deltas $>1$ at long maturities, not shown on this scale). }}{6}{figure.3}\protected@file@percent }
\newlabel{fig:causal-iv}{{3}{6}{\textbf {CausalSpectralFilter vs circular SpectralFilter ($\rho =-0.9$).} Each panel shows one maturity. BLP reference (black) has the correct left skew. Causal $z$-Cholesky (green dashed) tracks the reference closely at all strikes; causal $\rho =0$ baseline (blue dotted) matches the IV \emph {level} but not the skew. Circular $z$-Cholesky (red dash-dot) is physically invalid (IVs exceed 100\% and deltas $>1$ at long maturities, not shown on this scale)}{figure.3}{}}
\newlabel{fig:causal-iv@cref}{{[figure][3][]3}{[1][5][]6}{}{}{}}
