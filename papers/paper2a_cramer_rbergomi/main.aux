\newlabel{rem:filter-geometry@cref}{{[theorem][1][5]5.1}{[1][7][]7}{}{}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces \textbf  {Learned log-amplitude vs.\ theoretical Cholesky factor.} Blue: SpectralFilter learned $a_k$ after 3000 epochs. Orange: exact Cholesky factor $\tfrac  {1}{2}\log (S_H(f_k)\cdot N/(2\,\mathrm  {d}t))$. The maximum per-frequency gap $\max _k|\Delta a_k| = 2.77$ is identical for $H \in \{0.05, 0.10, 0.30\}$: the Bochner loss has a large solution manifold and the gradient descent finds a solution that satisfies the PSD constraint in expectation without converging to the Cholesky factor. }}{8}{figure.4}\protected@file@percent }
\newlabel{fig:filter-geometry}{{4}{8}{\textbf {Learned log-amplitude vs.\ theoretical Cholesky factor.} Blue: SpectralFilter learned $a_k$ after 3000 epochs. Orange: exact Cholesky factor $\tfrac {1}{2}\log (S_H(f_k)\cdot N/(2\,\mathrm {d}t))$. The maximum per-frequency gap $\max _k|\Delta a_k| = 2.77$ is identical for $H \in \{0.05, 0.10, 0.30\}$: the Bochner loss has a large solution manifold and the gradient descent finds a solution that satisfies the PSD constraint in expectation without converging to the Cholesky factor}{figure.4}{}}
\newlabel{fig:filter-geometry@cref}{{[figure][4][]4}{[1][7][]8}{}{}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {5.3}Hurst estimator comparison}{8}{subsection.5.3}\protected@file@percent }
\newlabel{sec:hurst-estimators}{{5.3}{8}{Hurst estimator comparison}{subsection.5.3}{}}
\newlabel{sec:hurst-estimators@cref}{{[subsection][3][5]5.3}{[1][7][]8}{}{}{}}
\@writefile{lot}{\contentsline {table}{\numberline {2}{\ignorespaces Hurst estimator comparison: bias and standard deviation ($N=252$, 300~paths per $H$). Structure function achieves smallest absolute bias ($|\text  {bias}|\leq 0.011$ for $H\leq 0.30$). Cram\'er exact achieves tightest standard deviation ($0.012$, nearly constant). PSD slope and R/S are unreliable for rough vol: PSD slope incurs severe negative bias at small $H$ ($-0.195$ at $H=0.05$); R/S has a large positive bias ($+0.20$) uniform in $H$.}}{8}{table.2}\protected@file@percent }
\newlabel{tab:hurst-estimators}{{2}{8}{Hurst estimator comparison: bias and standard deviation ($N=252$, 300~paths per $H$). Structure function achieves smallest absolute bias ($|\text {bias}|\leq 0.011$ for $H\leq 0.30$). Cram\'er exact achieves tightest standard deviation ($0.012$, nearly constant). PSD slope and R/S are unreliable for rough vol: PSD slope incurs severe negative bias at small $H$ ($-0.195$ at $H=0.05$); R/S has a large positive bias ($+0.20$) uniform in $H$}{table.2}{}}
\newlabel{tab:hurst-estimators@cref}{{[table][2][]2}{[1][8][]8}{}{}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces \textbf  {Hurst estimator comparison.} Violin plots of $\hat  {H}$ across 300 paths for each method. Structure function (blue) tracks the diagonal closely with small variance. Cram\'er exact (green) is tightest but has a $+0.055$ positive bias from the finite-$N$ frequency cutoff. PSD slope (orange) collapses near zero for $H\leq 0.10$; R/S (red) overshoots by $+0.20$ uniformly. }}{8}{figure.5}\protected@file@percent }
\newlabel{fig:hurst-estimators}{{5}{8}{\textbf {Hurst estimator comparison.} Violin plots of $\hat {H}$ across 300 paths for each method. Structure function (blue) tracks the diagonal closely with small variance. Cram\'er exact (green) is tightest but has a $+0.055$ positive bias from the finite-$N$ frequency cutoff. PSD slope (orange) collapses near zero for $H\leq 0.10$; R/S (red) overshoots by $+0.20$ uniformly}{figure.5}{}}
\newlabel{fig:hurst-estimators@cref}{{[figure][5][]5}{[1][8][]8}{}{}{}}
