\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces \textbf  {Hurst exponent recovery.} Estimated $\hat  {H}$ (structure-function OLS) vs.\ true $H$ for the SpectralFilter trained on exact (blue) and asymptotic (orange) PSD targets. The diagonal (dashed) is perfect recovery. Exact PSD training lies within $|\Delta H| \leq 0.013$ of the diagonal across the full rough-vol range $H \in [0.05, 0.50]$. The asymptotic target systematically over-estimates $H$ for $H \leq 0.3$ (bias up to $+0.09$ at $H=0.05$), consistent with Corollary~\ref {cor:hurst} and the mid-frequency PSD mis-match in Figure~\ref {fig:psd-comparison}. }}{7}{figure.3}\protected@file@percent }
\newlabel{fig:hurst-recovery}{{3}{7}{\textbf {Hurst exponent recovery.} Estimated $\hat {H}$ (structure-function OLS) vs.\ true $H$ for the SpectralFilter trained on exact (blue) and asymptotic (orange) PSD targets. The diagonal (dashed) is perfect recovery. Exact PSD training lies within $|\Delta H| \leq 0.013$ of the diagonal across the full rough-vol range $H \in [0.05, 0.50]$. The asymptotic target systematically over-estimates $H$ for $H \leq 0.3$ (bias up to $+0.09$ at $H=0.05$), consistent with Corollary~\ref {cor:hurst} and the mid-frequency PSD mis-match in Figure~\ref {fig:psd-comparison}}{figure.3}{}}
\newlabel{fig:hurst-recovery@cref}{{[figure][3][]3}{[1][7][]7}{}{}{}}
