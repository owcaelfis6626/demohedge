\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces \textbf  {Exact vs.\ asymptotic fGn spectral density, $H=0.1$.} \emph  {Main panel:} log--log plot of the exact Monte Carlo PSD (blue, averaged over $10^5$ Wood--Chan paths) and the asymptotic power-law $C|f|^{1-2H}$ (orange, normalised to equal total power). The two targets agree in slope but diverge in amplitude across the full frequency range. \emph  {Inset:} relative error $(S_{\mathrm  {exact}}-S_{\mathrm  {asymp}})/S_{\mathrm  {exact}}$; the asymptotic target over-estimates power at mid-frequencies by up to 15\%, which biases long-maturity option prices (see Table~\ref {tab:iv-rmse} and \cref  {fig:iv-surrogate}). }}{5}{figure.2}\protected@file@percent }
\newlabel{fig:psd-comparison}{{2}{5}{\textbf {Exact vs.\ asymptotic fGn spectral density, $H=0.1$.} \emph {Main panel:} log--log plot of the exact Monte Carlo PSD (blue, averaged over $10^5$ Wood--Chan paths) and the asymptotic power-law $C|f|^{1-2H}$ (orange, normalised to equal total power). The two targets agree in slope but diverge in amplitude across the full frequency range. \emph {Inset:} relative error $(S_{\mathrm {exact}}-S_{\mathrm {asymp}})/S_{\mathrm {exact}}$; the asymptotic target over-estimates power at mid-frequencies by up to 15\%, which biases long-maturity option prices (see Table~\ref {tab:iv-rmse} and \cref {fig:iv-surrogate})}{figure.2}{}}
\newlabel{fig:psd-comparison@cref}{{[figure][2][]2}{[1][5][]5}{}{}{}}
