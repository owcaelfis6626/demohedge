\@writefile{lot}{\contentsline {table}{\numberline {3}{\ignorespaces IV surface RMSE (vol points) vs.\ MC reference. Strikes $K/S_0 \in \{0.80, \ldots  , 1.20\}$, maturities $T \in \{0.25, 0.50, 1.00\}$. MC noise floor $\approx 1.0$~vp (10k paths). Primary calibration: $H=0.1$, $\eta =1.9$, $\xi _0=0.04$.}}{9}{table.3}\protected@file@percent }
\newlabel{tab:iv-rmse}{{3}{9}{IV surface RMSE (vol points) vs.\ MC reference. Strikes $K/S_0 \in \{0.80, \ldots , 1.20\}$, maturities $T \in \{0.25, 0.50, 1.00\}$. MC noise floor $\approx 1.0$~vp (10k paths). Primary calibration: $H=0.1$, $\eta =1.9$, $\xi _0=0.04$}{table.3}{}}
\newlabel{tab:iv-rmse@cref}{{[table][3][]3}{[1][8][]9}{}{}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces \textbf  {Implied volatility smiles: MC reference vs.\ surrogates.} Each panel shows one maturity ($T \in \{0.25, 0.50, 1.00\}$); $x$-axis is moneyness $K/S_0$, $y$-axis is IV in \%. RMSE (vol points) relative to the MC reference is shown in the legend. SpectralFilter (exact PSD) tracks the reference closely at all maturities; SpectralFilter (asymptotic) incurs a systematic upward bias at $T=1.00$ (3.20~vp), where the mid-frequency PSD mis-match propagates to long-dated smile levels. BochnerMLP achieves the lowest per-maturity RMSE despite generating non-Gaussian paths, confirming that the spectral loss is architecture-agnostic. }}{9}{figure.6}\protected@file@percent }
\newlabel{fig:iv-surrogate}{{6}{9}{\textbf {Implied volatility smiles: MC reference vs.\ surrogates.} Each panel shows one maturity ($T \in \{0.25, 0.50, 1.00\}$); $x$-axis is moneyness $K/S_0$, $y$-axis is IV in \%. RMSE (vol points) relative to the MC reference is shown in the legend. SpectralFilter (exact PSD) tracks the reference closely at all maturities; SpectralFilter (asymptotic) incurs a systematic upward bias at $T=1.00$ (3.20~vp), where the mid-frequency PSD mis-match propagates to long-dated smile levels. BochnerMLP achieves the lowest per-maturity RMSE despite generating non-Gaussian paths, confirming that the spectral loss is architecture-agnostic}{figure.6}{}}
\newlabel{fig:iv-surrogate@cref}{{[figure][6][]6}{[1][9][]9}{}{}{}}
\@writefile{toc}{\contentsline {paragraph}{PSD phase diagram.}{9}{section*.13}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {7}{\ignorespaces \textbf  {IV RMSE (vol points) by strike and maturity.} Colour scale: green $=$ low error, red $=$ high error. Each cell shows RMSE relative to the 10k-path MC reference. SpectralFilter (exact PSD) and BochnerMLP maintain near-uniform low error across the entire strike--maturity grid. SpectralFilter (asymptotic) shows a concentrated error mass at long maturities ($T=1.00$) and deep OTM puts ($K/S_0 \leq 0.85$), precisely the region where the power-law PSD approximation is least accurate. }}{10}{figure.7}\protected@file@percent }
\newlabel{fig:rmse-heatmap}{{7}{10}{\textbf {IV RMSE (vol points) by strike and maturity.} Colour scale: green $=$ low error, red $=$ high error. Each cell shows RMSE relative to the 10k-path MC reference. SpectralFilter (exact PSD) and BochnerMLP maintain near-uniform low error across the entire strike--maturity grid. SpectralFilter (asymptotic) shows a concentrated error mass at long maturities ($T=1.00$) and deep OTM puts ($K/S_0 \leq 0.85$), precisely the region where the power-law PSD approximation is least accurate}{figure.7}{}}
\newlabel{fig:rmse-heatmap@cref}{{[figure][7][]7}{[1][9][]10}{}{}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {8}{\ignorespaces \textbf  {PSD phase diagram.} Left: relative $L^2(\log )$ distance between exact and asymptotic fGn PSD as a function of $H$. Right: IV RMSE vs.\ MC reference for SpectralFilter trained on exact (blue) and asymptotic (orange) PSD. Below $H \approx 0.15$ (shaded) the exact target is essential; above $H = 0.20$ both targets achieve comparable accuracy. Baseline parameters: $\eta =1.9$, $\xi _0=0.04$, $\rho =0$, $N=252$. }}{10}{figure.8}\protected@file@percent }
\newlabel{fig:psd-phase}{{8}{10}{\textbf {PSD phase diagram.} Left: relative $L^2(\log )$ distance between exact and asymptotic fGn PSD as a function of $H$. Right: IV RMSE vs.\ MC reference for SpectralFilter trained on exact (blue) and asymptotic (orange) PSD. Below $H \approx 0.15$ (shaded) the exact target is essential; above $H = 0.20$ both targets achieve comparable accuracy. Baseline parameters: $\eta =1.9$, $\xi _0=0.04$, $\rho =0$, $N=252$}{figure.8}{}}
\newlabel{fig:psd-phase@cref}{{[figure][8][]8}{[1][9][]10}{}{}{}}
