\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces \textbf  {Roughness gallery.} Simulated fBm paths $W^H_t$ (top row) and instantaneous variance $V_t = \xi _0\exp (\eta W^H_t - \tfrac  {1}{2}\eta ^2 t^{2H})$ (bottom row) for $H \in \{0.50, 0.30, 0.10, 0.05\}$, with $\eta =1.9$, $\xi _0=0.04$. Decreasing $H$ produces increasingly rough, rapidly mean-reverting paths. The empirically calibrated value $H \approx 0.1$ (third column) generates the jagged, persistent variance clustering seen in equity markets. Standard Brownian motion ($H=0.5$, left) is manifestly too smooth. }}{3}{figure.1}\protected@file@percent }
\newlabel{fig:roughness-gallery}{{1}{3}{\textbf {Roughness gallery.} Simulated fBm paths $W^H_t$ (top row) and instantaneous variance $V_t = \xi _0\exp (\eta W^H_t - \tfrac {1}{2}\eta ^2 t^{2H})$ (bottom row) for $H \in \{0.50, 0.30, 0.10, 0.05\}$, with $\eta =1.9$, $\xi _0=0.04$. Decreasing $H$ produces increasingly rough, rapidly mean-reverting paths. The empirically calibrated value $H \approx 0.1$ (third column) generates the jagged, persistent variance clustering seen in equity markets. Standard Brownian motion ($H=0.5$, left) is manifestly too smooth}{figure.1}{}}
\newlabel{fig:roughness-gallery@cref}{{[figure][1][]1}{[1][3][]3}{}{}{}}
